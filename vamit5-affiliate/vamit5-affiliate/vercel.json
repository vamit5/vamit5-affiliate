{
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/r/:username",
      "destination": "https://bauuhowpbrqqmojqnqbr.supabase.co/functions/v1/redirect?u=:username"
    },
    {
      "source": "/r/:username/:slug",
      "destination": "https://bauuhowpbrqqmojqnqbr.supabase.co/functions/v1/redirect?u=:username&s=:slug"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "cleanUrls": true
}
